// 주기 타이머 측정 (비트 흐름과 무관, 메인 스레드에서 일정 주기로 측정)
// 렌더: dot -Tpng perf_timers.dot -o perf_timers.png
digraph timers {
  rankdir=LR;
  graph [fontname="Malgun Gothic", fontsize=13, labelloc=t,
         label="주기 타이머 측정 (자원·UI 응답성 — 일정 간격으로 자동 기록)"];
  node  [fontname="Malgun Gothic", fontsize=11, shape=box, style="rounded,filled"];
  edge  [fontname="Malgun Gothic", fontsize=10, style=dashed, color="#c2185b"];

  T1 [label="QTimer 1Hz\nSamplePerfResources", fillcolor="#bbdefb", color="#1565c0"];
  T2 [label="QTimer 0.1s\nSamplePerfUiResponsiveness", fillcolor="#bbdefb", color="#1565c0"];

  node [shape=note, fillcolor="#fce4ec", color="#c2185b"];
  R1 [label="cpu_percent (C-1)\nrss_bytes (D-1)\nthrottled_flag (C-2, Pi)"];
  R2 [label="ui_loop_lag_ms (A-3)\n→ UI가 멈추지 않나"];

  T1 -> R1;
  T2 -> R2;
}
